{
  "name": "claude-monitor",
  "version": "1.0.0",
  "description": "Terminal monitoring dashboard for Claude Code",
  "type": "module",
  "scripts": {
    "postinstall": "cp patches/blessed-widget.js node_modules/blessed/lib/widget.js",
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "bun build --compile src/index.ts --outfile build/claude-monitor"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "typescript": "^5.7.0"
  }
}
